    void docKyLuc() {
        try { ifstream f(CauHinh::FILE_KY_LUC); if (f) f >> diemKyLuc; }
        catch (...) { diemKyLuc = 0; }
    }
 
    void luuKyLuc(int diem) {
        try {
            if (diem > diemKyLuc) {
                diemKyLuc = diem;
                ofstream f(CauHinh::FILE_KY_LUC);
                if (f) f << diemKyLuc;
            }
        } catch (...) {}
    }
 
    void luuGame1Nguoi() {
        try {
            ofstream f(CauHinh::FILE_LUU_1P, ios::binary); if (!f) return;
            nguoiChoi1.luuTrangThai(f);
            ghiSoNguyen(f, mucTocDo);
        } catch (...) {}
    }
 
    bool napGame1Nguoi() {
        try {
            ifstream f(CauHinh::FILE_LUU_1P, ios::binary); if (!f) return false;
            nguoiChoi1.khoiDong(Color(50,220,80));
            nguoiChoi1.napTrangThai(f);
            mucTocDo = docSoNguyen(f);
            if (mucTocDo < 0 || mucTocDo > 2) mucTocDo = 1;
            return true;
        } catch (...) { return false; }
    }
 
