    // ---- Game flow ----
    void batDauGame() {
        m_nguoiChoi1DaThua = m_nguoiChoi2DaThua = false;
        if (m_choDoiKhang) {
            m_nguoiChoi1.khoiDong(Color(50,220,80)); m_nguoiChoi2.khoiDong(Color(220,80,80));
            m_trangThai = TrangThaiGame::DoiKhang;
        } else if (!m_cho2Nguoi) {
            m_nguoiChoi1.khoiDong(Color(50,220,80));
            m_trangThai = TrangThaiGame::Choi1Nguoi;
        } else {
            m_nguoiChoi1.khoiDong(Color(50,220,80)); m_nguoiChoi2.khoiDong(Color(220,80,80));
            m_trangThai = TrangThaiGame::Choi2Nguoi;
        }
        m_thoiGianTich = 0;
    }

    void xuLyPhimNhan(Event& sk) {
        using KB = Keyboard; using TS = TrangThaiGame;
        if (m_trangThai == TS::Menu) {
            if (sk.key.code == KB::Num1) { m_cho2Nguoi=false; m_choDoiKhang=false; m_trangThai=TS::ChonTocDo; }
            if (sk.key.code == KB::Num2) { m_cho2Nguoi=true;  m_choDoiKhang=false; m_trangThai=TS::ChonTocDo; }
            if (sk.key.code == KB::Num3) { m_cho2Nguoi=false; m_choDoiKhang=true;  m_trangThai=TS::ChonTocDo; }
            if (sk.key.code == KB::Num4) m_trangThai=TS::HuongDan;
            if (sk.key.code == KB::Num5) m_trangThai=TS::KyLuc;
            if (sk.key.code == KB::Num6) m_cuaSo.close();
            if (sk.key.code == KB::Num7 && coFileLuu1P())
                if (napGame1Nguoi()) { m_trangThai=TS::Choi1Nguoi; m_thoiGianTich=0; }
            if (sk.key.code == KB::Num8 && coFileLuu2P())
                if (napGame2Nguoi()) { m_trangThai=TS::Choi2Nguoi; m_thoiGianTich=0; }
        } else if (m_trangThai == TS::ChonTocDo) {
            if (sk.key.code == KB::Num1) { m_mucTocDo=0; batDauGame(); }
            if (sk.key.code == KB::Num2) { m_mucTocDo=1; batDauGame(); }
            if (sk.key.code == KB::Num3) { m_mucTocDo=2; batDauGame(); }
            if (sk.key.code == KB::Escape) m_trangThai=TS::Menu;
        } else if (m_trangThai == TS::HuongDan || m_trangThai == TS::KyLuc) {
            if (sk.key.code == KB::Escape) m_trangThai=TS::Menu;
        } else {
            if (sk.key.code == KB::Escape) {
                if (m_trangThai==TS::Choi1Nguoi) luuGame1Nguoi();
                if (m_trangThai==TS::Choi2Nguoi) luuGame2Nguoi();
                m_trangThai=TS::Menu;
            }
            bool nc1 = (m_trangThai==TS::Choi1Nguoi || m_trangThai==TS::Choi2Nguoi ||
                        m_trangThai==TS::DoiKhang) && !m_nguoiChoi1DaThua;
            if (nc1) {
                if (sk.key.code==KB::Left)  m_nguoiChoi1.diChuyen(-1);
                if (sk.key.code==KB::Right) m_nguoiChoi1.diChuyen(1);
                if (sk.key.code==KB::Up)    m_nguoiChoi1.xoay();
                if (sk.key.code==KB::Down)  m_nguoiChoi1.reNhanh();
            }
            bool nc2 = (m_trangThai==TS::Choi2Nguoi || m_trangThai==TS::DoiKhang) && !m_nguoiChoi2DaThua;
            if (nc2) {
                if (sk.key.code==KB::A) m_nguoiChoi2.diChuyen(-1);
                if (sk.key.code==KB::D) m_nguoiChoi2.diChuyen(1);
                if (sk.key.code==KB::W) m_nguoiChoi2.xoay();
                if (sk.key.code==KB::S) m_nguoiChoi2.reNhanh();
            }
        }
    }

