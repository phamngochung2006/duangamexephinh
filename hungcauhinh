struct CauHinh {
    static constexpr int COT = 10;
    static constexpr int HANG = 20;
    static constexpr int O_SIZE = 28;
    static constexpr int SO_KIEU = 7;
    static constexpr int MAU_RAC = 8;   // chi so mau hang rac 
    static constexpr float TOC_DE = 0.60f;
    static constexpr float TOC_TRUNG = 0.38f;
    static constexpr float TOC_KHO = 0.18f;
    static constexpr const char* FILE_LUU_1P = "xephim_save.dat";
    static constexpr const char* FILE_LUU_2P = "xephim_save_2p.dat";
    static constexpr const char* FILE_KY_LUC = "highscore.txt";
};
// Cau hinh toc do - truy cap qua chi so mucDo (0=De, 1=Trung, 2=Kho)
static const float    BANG_TOC_DO[] = { CauHinh::TOC_DE, CauHinh::TOC_TRUNG, CauHinh::TOC_KHO };
static const char* NHAN_TOC_DO[] = { "DE", "TRUNG BINH", "KHO" };
 CAC KHOI XEP HINH - index theo cot/hang trong o 2x4
static int dinhNghiaKhoi[CauHinh::SO_KIEU][4] = {
    {1,3,5,7}, // I
    {2,4,5,7}, // S
    {3,5,4,6}, // Z
    {3,5,4,7}, // T
    {2,3,5,7}, // L
    {3,5,7,6}, // J
    {2,3,4,5}  // O
};
static Color bangMauKhoi[CauHinh::SO_KIEU] = {
    Color(0,220,220),   // I - xanh nhat
    Color(0,200,50),    // S - xanh la
    Color(220,50,50),   // Z - do
    Color(160,0,220),   // T - tim
    Color(220,140,0),   // L - cam
    Color(0,80,220),    // J - xanh duong
    Color(220,220,0),   // O - vang
};
struct HieuUngDiem {
    float x, y, tocDoDoc, doMo, thoiGianCon;
    string noiDung;
    HieuUngDiem(float px, float py, int diem) {
        x = px; y = py;
        tocDoDoc = -150.f;
        doMo = 255.f;
        thoiGianCon = 0.5f;
        noiDung = "+" + to_string(diem);
    }
    // Tra ve false khi het thoi gian -> xoa khoi danh sach
    bool capNhat(float dt) {
        y += tocDoDoc * dt;
        doMo -= 200.f * dt;
        thoiGianCon -= dt;
        return thoiGianCon > 0;
    }
};
struct ToaDo { int x, y; };
class BanChoiDon {
public:
    int  luoi[CauHinh::HANG][CauHinh::COT]{};
    int  luoiMau[CauHinh::HANG][CauHinh::COT]{};
    ToaDo khoiHienTai[4], khoiDuPhong[4];
    int  kieuHienTai = 0;
    int  kieuTiepTheo = 0;
    int  diem = 0;
    bool daGameOver = false;
    Color mauNguoiChoi;
    bool dangXoaHang = false;
    int  demHieuUng = 0;
    bool hangDay[CauHinh::HANG]{};
    vector<HieuUngDiem> danhSachHieuUng;
    int  hangRacCho = 0;
     void khoiDong(Color mau) {
        mauNguoiChoi = mau;
        kieuTiepTheo = rand() % CauHinh::SO_KIEU;
        diem = 0;
        daGameOver = false;
        hangRacCho = 0;
        danhSachHieuUng.clear();
        for (int i = 0; i < CauHinh::HANG; i++)
            for (int j = 0; j < CauHinh::COT; j++)
                luoi[i][j] = luoiMau[i][j] = 0;
        taoBienMoi();
    }
 // ----------------------------------------------------------
    //  Tao khoi moi tren dinh ban choi
    // ----------------------------------------------------------
    void taoBienMoi() {
        kieuHienTai = kieuTiepTheo;
        kieuTiepTheo = rand() % CauHinh::SO_KIEU;
        for (int i = 0; i < 4; i++) {
            khoiHienTai[i].x = dinhNghiaKhoi[kieuHienTai][i] % 2 + CauHinh::COT / 2 - 1;
            khoiHienTai[i].y = dinhNghiaKhoi[kieuHienTai][i] / 2;
        }
        if (!kiemTraHopLe()) daGameOver = true;
    }

    // ----------------------------------------------------------
    //  Kiem tra vi tri khoiHienTai co hop le khong
    // ----------------------------------------------------------
    bool kiemTraHopLe() {
        for (int i = 0; i < 4; i++) {
            int cx = khoiHienTai[i].x, cy = khoiHienTai[i].y;
            if (cx < 0 || cx >= CauHinh::COT || cy >= CauHinh::HANG) return false;
            if (cy >= 0 && luoi[cy][cx]) return false;
        }
        return true;
    }

    // ----------------------------------------------------------
    //  Khoa khoi xuong luoi khi cham day (dung khoiDuPhong)
    // ----------------------------------------------------------
    void khoaKhoiXuongLuoi() {
        for (int i = 0; i < 4; i++) {
            luoi[khoiDuPhong[i].y][khoiDuPhong[i].x] = 1;
            luoiMau[khoiDuPhong[i].y][khoiDuPhong[i].x] = kieuHienTai + 1;
        }
    }

    // ----------------------------------------------------------
    //  Dem va danh dau cac hang da day
    // ----------------------------------------------------------
    int demHangDay() {
        int soHang = 0;
        for (int i = 0; i < CauHinh::HANG; i++) {
            int soO = 0;
            for (int j = 0; j < CauHinh::COT; j++) if (luoi[i][j]) soO++;
            hangDay[i] = (soO == CauHinh::COT);
            if (hangDay[i]) soHang++;
        }
        return soHang;
    }

    // ----------------------------------------------------------
    //  Xoa cac hang da day, don cac hang con lai xuong duoi
    // ----------------------------------------------------------
    void xoaHangDayVaDon() {
        int k = CauHinh::HANG - 1;
        for (int i = CauHinh::HANG - 1; i >= 0; i--) {
            if (!hangDay[i]) {
                for (int j = 0; j < CauHinh::COT; j++) {
                    luoi[k][j] = luoi[i][j];
                    luoiMau[k][j] = luoiMau[i][j];
                }
                k--;
            }
        }
    }
// ----------------------------------------------------------
    //  Tinh diem theo so hang xoa duoc
    // ----------------------------------------------------------
    int tinhDiemTheoSoHang(int soHang) {
        switch (soHang) {
        case 1:  return 100;
        case 2:  return 300;
        case 3:  return 600;
        case 4:  return 1000;
        default: return 0;
        }
    }

    // ----------------------------------------------------------
    //  Cap nhat 1 buoc roi (goi moi tick game)
    //  Tra ve so hang da xoa - de xu ly gui rac o che do doi khang
    // ----------------------------------------------------------
    int buocRoi(float viTriNgang) {
        // Dang trong animation xoa hang -> dem lui, het thi don luoi
        if (dangXoaHang) {
            if (--demHieuUng <= 0) {
                xoaHangDayVaDon();
                dangXoaHang = false;
            }
            return 0;
        }

        // Thu di chuyen khoi xuong 1 o
        for (int i = 0; i < 4; i++) {
            khoiDuPhong[i] = khoiHienTai[i];
            khoiHienTai[i].y++;
        }

        // Neu khong hop le -> khoa khoi, kiem tra xoa hang, tao bien moi
        if (!kiemTraHopLe()) {
            for (int i = 0; i < 4; i++) khoiHienTai[i] = khoiDuPhong[i];
            khoaKhoiXuongLuoi();

            int soHangXoa = demHangDay();
            if (soHangXoa > 0) {
                dangXoaHang = true;
                demHieuUng = 2;
                int diemKiemDuoc = tinhDiemTheoSoHang(soHangXoa);
                diem += diemKiemDuoc;

                float ex = viTriNgang + (CauHinh::COT * CauHinh::O_SIZE) / 2.f;
                float ey = CauHinh::HANG * CauHinh::O_SIZE / 2.f;
                danhSachHieuUng.push_back(HieuUngDiem(ex, ey, diemKiemDuoc));
                if (soHangXoa == 4) {
                    danhSachHieuUng.push_back(HieuUngDiem(ex - 20, ey + 30, 0));
                    danhSachHieuUng.back().noiDung = "TETRIS!";
                }
            }
            taoBienMoi();
            return soHangXoa;
        }
        return 0;
    }
  // ----------------------------------------------------------
    void diChuyen(int dx) {
        for (int i = 0; i < 4; i++) { khoiDuPhong[i] = khoiHienTai[i]; khoiHienTai[i].x += dx; }
        if (!kiemTraHopLe()) for (int i = 0; i < 4; i++) khoiHienTai[i] = khoiDuPhong[i];
    }
 
    void xoay() {
        ToaDo tamXoay = khoiHienTai[1];
        for (int i = 0; i < 4; i++) {
            int dx = khoiHienTai[i].y - tamXoay.y;
            int dy = khoiHienTai[i].x - tamXoay.x;
            khoiDuPhong[i]   = khoiHienTai[i];
            khoiHienTai[i].x = tamXoay.x - dx;
            khoiHienTai[i].y = tamXoay.y + dy;
        }
        if (!kiemTraHopLe()) for (int i = 0; i < 4; i++) khoiHienTai[i] = khoiDuPhong[i];
    }
 
    void reNhanh() {
        while (true) {
            for (int i = 0; i < 4; i++) { khoiDuPhong[i] = khoiHienTai[i]; khoiHienTai[i].y++; }
            if (!kiemTraHopLe()) { for (int i = 0; i < 4; i++) khoiHienTai[i] = khoiDuPhong[i]; break; }
        }
    }
 
    // ----------------------------------------------------------
    //  Tinh vi tri bong (ghost piece) de hien thi
    // ----------------------------------------------------------
    void tinhViTriBong(ToaDo bong[4]) {
        for (int i = 0; i < 4; i++) bong[i] = khoiHienTai[i];
        ToaDo tam[4];
        while (true) {
            for (int i = 0; i < 4; i++) { tam[i] = bong[i]; bong[i].y++; }
            bool hopLe = true;
            for (int i = 0; i < 4; i++) {
                if (bong[i].x < 0 || bong[i].x >= CauHinh::COT || bong[i].y >= CauHinh::HANG)
                    { hopLe = false; break; }
                if (bong[i].y >= 0 && luoi[bong[i].y][bong[i].x])
                    { hopLe = false; break; }
            }
            if (!hopLe) { for (int i = 0; i < 4; i++) bong[i] = tam[i]; break; }
        }
    }
 
    // ----------------------------------------------------------
    //  Nhan hang rac tu doi thu (che do doi khang)
    // ----------------------------------------------------------
    void nhanHangRac(int soHang) {
        if (soHang <= 0) return;
        for (int i = 0; i < CauHinh::HANG - soHang; i++)
            for (int j = 0; j < CauHinh::COT; j++) {
                luoi[i][j]    = luoi[i + soHang][j];
                luoiMau[i][j] = luoiMau[i + soHang][j];
            }
        int viTriLo = rand() % CauHinh::COT;
        for (int i = CauHinh::HANG - soHang; i < CauHinh::HANG; i++)
            for (int j = 0; j < CauHinh::COT; j++) {
                luoi[i][j]    = (j == viTriLo) ? 0 : 1;
                luoiMau[i][j] = (j == viTriLo) ? 0 : CauHinh::MAU_RAC;
            }
        for (int k = 0; k < soHang; k++) {
            bool biChong = false;
            for (int i = 0; i < 4; i++)
                if (khoiHienTai[i].y >= 0 && khoiHienTai[i].y < CauHinh::HANG
                    && luoi[khoiHienTai[i].y][khoiHienTai[i].x])
                    { biChong = true; break; }
            if (biChong) for (int i = 0; i < 4; i++) khoiHienTai[i].y--;
        }
    }
 
    void capNhatHieuUng(float dt) {
        for (int i = (int)danhSachHieuUng.size() - 1; i >= 0; i--)
            if (!danhSachHieuUng[i].capNhat(dt))
                danhSachHieuUng.erase(danhSachHieuUng.begin() + i);
    }
 
    // ----------------------------------------------------------
    //  LUU / NAP TRANG THAI
    // ----------------------------------------------------------
    void luuTrangThai(ofstream& f) {
        for (int i = 0; i < CauHinh::HANG; i++)
            for (int j = 0; j < CauHinh::COT; j++) {
                ghiSoNguyen(f, luoi[i][j]);
                ghiSoNguyen(f, luoiMau[i][j]);
            }
        for (int i = 0; i < 4; i++) {
            ghiSoNguyen(f, khoiHienTai[i].x);
            ghiSoNguyen(f, khoiHienTai[i].y);
        }
        ghiSoNguyen(f, kieuHienTai);
        ghiSoNguyen(f, kieuTiepTheo);
        ghiSoNguyen(f, diem);
    }
 
    void napTrangThai(ifstream& f) {
        for (int i = 0; i < CauHinh::HANG; i++)
            for (int j = 0; j < CauHinh::COT; j++) {
                luoi[i][j]    = docSoNguyen(f);
                luoiMau[i][j] = docSoNguyen(f);
            }
        for (int i = 0; i < 4; i++) {
            khoiHienTai[i].x = docSoNguyen(f);
            khoiHienTai[i].y = docSoNguyen(f);
        }
        kieuHienTai  = docSoNguyen(f);
        kieuTiepTheo = docSoNguyen(f);
        diem         = docSoNguyen(f);
        daGameOver   = false;
        dangXoaHang  = false;
        hangRacCho   = 0;
        danhSachHieuUng.clear();
    }

    // ----------------------------------------------------------
    //  VE BAN CHOI
    // ----------------------------------------------------------
    void veBanChoi(RenderWindow& cua_so, int viTriNgang, Font& phong_chu) {
        RectangleShape nen(Vector2f(CauHinh::COT * CauHinh::O_SIZE, CauHinh::HANG * CauHinh::O_SIZE));
        nen.setPosition(viTriNgang, 0);
        nen.setFillColor(Color(15, 15, 30));
        cua_so.draw(nen);
 
        RectangleShape duongDoc(Vector2f(1, CauHinh::HANG * CauHinh::O_SIZE));
        duongDoc.setFillColor(Color(40, 40, 60));
        for (int j = 1; j < CauHinh::COT; j++) {
            duongDoc.setPosition(viTriNgang + j * CauHinh::O_SIZE, 0);
            cua_so.draw(duongDoc);
        }
        RectangleShape duongNgang(Vector2f(CauHinh::COT * CauHinh::O_SIZE, 1));
        duongNgang.setFillColor(Color(40, 40, 60));
        for (int i = 1; i < CauHinh::HANG; i++) {
            duongNgang.setPosition(viTriNgang, i * CauHinh::O_SIZE);
            cua_so.draw(duongNgang);
        }
 
        RectangleShape o(Vector2f(CauHinh::O_SIZE - 2.f, CauHinh::O_SIZE - 2.f));
        for (int i = 0; i < CauHinh::HANG; i++)
            for (int j = 0; j < CauHinh::COT; j++) {
                if (!luoi[i][j]) continue;
                int ci = luoiMau[i][j] - 1;
                Color mauO;
                if (ci == CauHinh::MAU_RAC - 1) mauO = Color(100, 100, 100);
                else mauO = (ci >= 0 && ci < CauHinh::SO_KIEU) ? bangMauKhoi[ci] : mauNguoiChoi;
                if (dangXoaHang && hangDay[i])
                    mauO = (demHieuUng % 3 == 0) ? Color::White
                                                 : Color(mauO.r/2, mauO.g/2, mauO.b/2);
                o.setFillColor(mauO);
                o.setPosition(viTriNgang + j * CauHinh::O_SIZE + 1, i * CauHinh::O_SIZE + 1);
                cua_so.draw(o);
                RectangleShape sang(Vector2f(CauHinh::O_SIZE - 2.f, 3.f));
                sang.setFillColor(Color(255, 255, 255, 60));
                sang.setPosition(viTriNgang + j * CauHinh::O_SIZE + 1, i * CauHinh::O_SIZE + 1);
                cua_so.draw(sang);
            }
 
        ToaDo bong[4]; tinhViTriBong(bong);
        Color mauBong = bangMauKhoi[kieuHienTai]; mauBong.a = 60;
        o.setFillColor(mauBong);
        for (int i = 0; i < 4; i++)
            if (bong[i].y >= 0) {
                o.setPosition(viTriNgang + bong[i].x * CauHinh::O_SIZE + 1,
                               bong[i].y * CauHinh::O_SIZE + 1);
                cua_so.draw(o);
            }
 
        Color mauKhoi = bangMauKhoi[kieuHienTai]; mauKhoi.a = 255;
        o.setFillColor(mauKhoi);
        for (int i = 0; i < 4; i++)
            if (khoiHienTai[i].y >= 0) {
                o.setPosition(viTriNgang + khoiHienTai[i].x * CauHinh::O_SIZE + 1,
                               khoiHienTai[i].y * CauHinh::O_SIZE + 1);
                cua_so.draw(o);
                RectangleShape sang(Vector2f(CauHinh::O_SIZE - 2.f, 3.f));
                sang.setFillColor(Color(255, 255, 255, 80));
                sang.setPosition(viTriNgang + khoiHienTai[i].x * CauHinh::O_SIZE + 1,
                                  khoiHienTai[i].y * CauHinh::O_SIZE + 1);
                cua_so.draw(sang);
            }
 
        RectangleShape khung(Vector2f(CauHinh::COT * CauHinh::O_SIZE, CauHinh::HANG * CauHinh::O_SIZE));
        khung.setPosition(viTriNgang, 0);
        khung.setFillColor(Color::Transparent);
        khung.setOutlineThickness(2);
        khung.setOutlineColor(Color(100, 100, 160));
        cua_so.draw(khung);
    }
 
    // ----------------------------------------------------------
    void vePanel(RenderWindow& cua_so, int panelX, int panelY, Font& phong_chu, const string& nhan) {
        RectangleShape nen(Vector2f(130, 310));
        nen.setPosition(panelX, panelY);
        nen.setFillColor(Color(20, 20, 40, 200));
        nen.setOutlineThickness(1);
        nen.setOutlineColor(Color(80, 80, 120));
        cua_so.draw(nen);
 
        auto veChu = [&](const string& s, int x, int y, int cz, Color c) {
            Text t(s, phong_chu, cz); t.setPosition((float)x, (float)y); t.setFillColor(c); cua_so.draw(t);
        };
        veChu(nhan,                 panelX+10, panelY+8,  16, mauNguoiChoi);
        veChu("DIEM",               panelX+10, panelY+35, 12, Color(160,160,200));
        veChu(to_string(diem),      panelX+10, panelY+52, 22, Color::White);
        veChu("TIEP THEO",          panelX+10, panelY+90, 12, Color(160,160,200));
 
        int coChuKhoi = 22;
        ToaDo xemTruoc[4];
        for (int i = 0; i < 4; i++) {
            xemTruoc[i].x = dinhNghiaKhoi[kieuTiepTheo][i] % 2;
            xemTruoc[i].y = dinhNghiaKhoi[kieuTiepTheo][i] / 2;
        }
        RectangleShape oXem(Vector2f(coChuKhoi - 2.f, coChuKhoi - 2.f));
        oXem.setFillColor(bangMauKhoi[kieuTiepTheo]);
        int gocX = panelX + 30, gocY = panelY + 115;
        for (int i = 0; i < 4; i++) {
            oXem.setPosition(gocX + xemTruoc[i].x * coChuKhoi, gocY + xemTruoc[i].y * coChuKhoi);
            cua_so.draw(oXem);
        }
 
        if (hangRacCho > 0)
            veChu("RAC: " + to_string(hangRacCho), panelX+10, panelY+190, 13, Color(255,80,80));
    }
 
    // ----------------------------------------------------------
    void veHieuUngDiem(RenderWindow& cua_so, Font& phong_chu) {
        for (auto& hu : danhSachHieuUng) {
            bool laTetris = (hu.noiDung == "TETRIS!");
            Text t(hu.noiDung, phong_chu, laTetris ? 26 : 22);
            Uint8 doMo = (Uint8)max(0.f, hu.doMo);
            t.setFillColor(laTetris ? Color(255,220,0,doMo) : Color(100,255,100,doMo));
            t.setOutlineColor(Color(0,0,0,doMo));
            t.setOutlineThickness(2);
            t.setPosition(hu.x - t.getLocalBounds().width / 2.f, hu.y);
            cua_so.draw(t);
        }
    }
};
