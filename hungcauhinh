    // ---- Luu/Nap ----
    void docKyLuc() {
        try { ifstream f(CauHinh::FILE_KY_LUC); if (f) f >> m_diemKyLuc; }
        catch (...) { m_diemKyLuc = 0; }
    }
    void luuKyLuc(int diem) {
        try {
            if (diem > m_diemKyLuc) {
                m_diemKyLuc = diem;
                ofstream f(CauHinh::FILE_KY_LUC); if (f) f << m_diemKyLuc;
            }
        } catch (...) {}
    }
    void luuGame1Nguoi() {
        try {
            ofstream f(CauHinh::FILE_LUU_1P, ios::binary); if (!f) return;
            m_nguoiChoi1.luuTrangThai(f); ghiSoNguyen(f, m_mucTocDo);
        } catch (...) {}
    }
    bool napGame1Nguoi() {
        try {
            ifstream f(CauHinh::FILE_LUU_1P, ios::binary); if (!f) return false;
            m_nguoiChoi1.khoiDong(Color(50,220,80)); m_nguoiChoi1.napTrangThai(f);
            m_mucTocDo = docSoNguyen(f);
            if (m_mucTocDo < 0 || m_mucTocDo > 2) m_mucTocDo = 1;
            return true;
        } catch (...) { return false; }
    }
    void luuGame2Nguoi() {
        try {
            ofstream f(CauHinh::FILE_LUU_2P, ios::binary); if (!f) return;
            m_nguoiChoi1.luuTrangThai(f); m_nguoiChoi2.luuTrangThai(f); ghiSoNguyen(f, m_mucTocDo);
        } catch (...) {}
    }
    bool napGame2Nguoi() {
        try {
            ifstream f(CauHinh::FILE_LUU_2P, ios::binary); if (!f) return false;
            m_nguoiChoi1.khoiDong(Color(50,220,80)); m_nguoiChoi2.khoiDong(Color(220,80,80));
            m_nguoiChoi1.napTrangThai(f); m_nguoiChoi2.napTrangThai(f);
            m_mucTocDo = docSoNguyen(f);
            if (m_mucTocDo < 0 || m_mucTocDo > 2) m_mucTocDo = 1;
            return true;
        } catch (...) { return false; }
    }
