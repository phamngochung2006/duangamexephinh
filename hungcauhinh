static const float    BANG_TOC_DO[] = { CauHinh::TOC_DE, CauHinh::TOC_TRUNG, CauHinh::TOC_KHO };
static const char* NHAN_TOC_DO[] = { "DE", "TRUNG BINH", "KHO" };
 CAC KHOI XEP HINH - index theo cot/hang trong o 2x4
