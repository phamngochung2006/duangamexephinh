struct CauHinh {
    static constexpr int COT     = 10;
    static constexpr int HANG    = 20;
    static constexpr int O_SIZE  = 28;
    static constexpr int SO_KIEU = 7;
    static constexpr int MAU_RAC = 8;

    static constexpr float TOC_DE    = 0.60f;
    static constexpr float TOC_TRUNG = 0.38f;
    static constexpr float TOC_KHO   = 0.18f;

    static constexpr const char* FILE_LUU_1P = "xephim_save.dat";
    static constexpr const char* FILE_LUU_2P = "xephim_save_2p.dat";
    static constexpr const char* FILE_KY_LUC = "highscore.txt";
};

static const float  BANG_TOC_DO[] = { CauHinh::TOC_DE, CauHinh::TOC_TRUNG, CauHinh::TOC_KHO };
static const char*  NHAN_TOC_DO[] = { "DE", "TRUNG BINH", "KHO" };

static int dinhNghiaKhoi[CauHinh::SO_KIEU][4] = {
    {1,3,5,7}, // I
    {2,4,5,7}, // S
    {3,5,4,6}, // Z
    {3,5,4,7}, // T
    {2,3,5,7}, // L
    {3,5,7,6}, // J
    {2,3,4,5}  // O
};

static Color bangMauKhoi[CauHinh::SO_KIEU] = {
    Color(0,220,220), Color(0,200,50),  Color(220,50,50),
    Color(160,0,220), Color(220,140,0), Color(0,80,220),
    Color(220,220,0)
};

// ============================================================
//  TOA DO
// ============================================================
struct ToaDo { int x, y; };

// ============================================================
//  TIEN ICH DOC/GHI FILE
// ============================================================
void ghiSoNguyen(ofstream& f, int gia_tri) {
    f.write(reinterpret_cast<const char*>(&gia_tri), sizeof(gia_tri));
    if (!f) throw runtime_error("Loi ghi file");
}
int docSoNguyen(ifstream& f) {
    int gia_tri = 0;
    f.read(reinterpret_cast<char*>(&gia_tri), sizeof(gia_tri));
    if (!f) throw runtime_error("Loi doc file");
    return gia_tri;
}

// ============================================================
//  CLASS HIEUUNGDIEM
// ============================================================
class HieuUngDiem {
private:
    float  m_x, m_y, m_tocDoDoc, m_doMo, m_thoiGianCon;
    string m_noiDung;

public:
    HieuUngDiem(float px, float py, int diem) {
        m_x = px; m_y = py;
        m_tocDoDoc    = -150.f;
        m_doMo        = 255.f;
        m_thoiGianCon = 0.5f;
        m_noiDung     = "+" + to_string(diem);
    }

    // --- Getters ---
    float  getX()          const { return m_x; }
    float  getY()          const { return m_y; }
    float  getDoMo()       const { return m_doMo; }
    string getNoiDung()    const { return m_noiDung; }

    // --- Setters ---
    void setNoiDung(const string& nd) { m_noiDung = nd; }

    bool capNhat(float dt) {
        m_y           += m_tocDoDoc * dt;
        m_doMo        -= 200.f * dt;
        m_thoiGianCon -= dt;
        return m_thoiGianCon > 0;
    }
};

// ============================================================
//  CLASS BANCHOIDON
// ============================================================
class BanChoiDon {
private:
    int       m_luoi   [CauHinh::HANG][CauHinh::COT]{};
    int       m_luoiMau[CauHinh::HANG][CauHinh::COT]{};
    ToaDo     m_khoiHienTai[4];
    ToaDo     m_khoiDuPhong[4];
    int       m_kieuHienTai  = 0;
    int       m_kieuTiepTheo = 0;
    int       m_diem         = 0;
    bool      m_daGameOver   = false;
    Color     m_mauNguoiChoi;
    bool      m_dangXoaHang  = false;
    int       m_demHieuUng   = 0;
    bool      m_hangDay[CauHinh::HANG]{};
    vector<HieuUngDiem> m_danhSachHieuUng;
    int       m_hangRacCho   = 0;

    // --- Noi bo ---
    void taoBienMoi() {
        m_kieuHienTai  = m_kieuTiepTheo;
        m_kieuTiepTheo = rand() % CauHinh::SO_KIEU;
        for (int i = 0; i < 4; i++) {
            m_khoiHienTai[i].x = dinhNghiaKhoi[m_kieuHienTai][i] % 2 + CauHinh::COT / 2 - 1;
            m_khoiHienTai[i].y = dinhNghiaKhoi[m_kieuHienTai][i] / 2;
        }
        if (!kiemTraHopLe()) m_daGameOver = true;
    }

    bool kiemTraHopLe() {
        for (int i = 0; i < 4; i++) {
            int cx = m_khoiHienTai[i].x, cy = m_khoiHienTai[i].y;
            if (cx < 0 || cx >= CauHinh::COT || cy >= CauHinh::HANG) return false;
            if (cy >= 0 && m_luoi[cy][cx]) return false;
        }
        return true;
    }

    void khoaKhoiXuongLuoi() {
        for (int i = 0; i < 4; i++) {
            m_luoi   [m_khoiDuPhong[i].y][m_khoiDuPhong[i].x] = 1;
            m_luoiMau[m_khoiDuPhong[i].y][m_khoiDuPhong[i].x] = m_kieuHienTai + 1;
        }
    }

    int demHangDay() {
        int soHang = 0;
        for (int i = 0; i < CauHinh::HANG; i++) {
            int soO = 0;
            for (int j = 0; j < CauHinh::COT; j++) if (m_luoi[i][j]) soO++;
            m_hangDay[i] = (soO == CauHinh::COT);
            if (m_hangDay[i]) soHang++;
        }
        return soHang;
    }

    void xoaHangDayVaDon() {
        int k = CauHinh::HANG - 1;
        for (int i = CauHinh::HANG - 1; i >= 0; i--)
            if (!m_hangDay[i]) {
                for (int j = 0; j < CauHinh::COT; j++) {
                    m_luoi   [k][j] = m_luoi   [i][j];
                    m_luoiMau[k][j] = m_luoiMau[i][j];
                }
                k--;
            }
    }

    int tinhDiemTheoSoHang(int soHang) {
        switch (soHang) {
        case 1: return 100; case 2: return 300;
        case 3: return 600; case 4: return 1000;
        default: return 0;
        }
    }

    void tinhViTriBong(ToaDo bong[4]) {
        for (int i = 0; i < 4; i++) bong[i] = m_khoiHienTai[i];
        ToaDo tam[4];
        while (true) {
            for (int i = 0; i < 4; i++) { tam[i] = bong[i]; bong[i].y++; }
            bool hopLe = true;
            for (int i = 0; i < 4; i++) {
                if (bong[i].x < 0 || bong[i].x >= CauHinh::COT || bong[i].y >= CauHinh::HANG)
                { hopLe = false; break; }
                if (bong[i].y >= 0 && m_luoi[bong[i].y][bong[i].x])
                { hopLe = false; break; }
            }
            if (!hopLe) { for (int i = 0; i < 4; i++) bong[i] = tam[i]; break; }
        }
    }

public:
    // ---- Khoi tao ----
    void khoiDong(Color mau) {
        m_mauNguoiChoi = mau;
        m_kieuTiepTheo = rand() % CauHinh::SO_KIEU;
        m_diem = 0; m_daGameOver = false; m_hangRacCho = 0;
        m_danhSachHieuUng.clear();
        for (int i = 0; i < CauHinh::HANG; i++)
            for (int j = 0; j < CauHinh::COT; j++)
                m_luoi[i][j] = m_luoiMau[i][j] = 0;
        taoBienMoi();
    }

    // ---- Getters ----
    int   getDiem()           const { return m_diem; }
    bool  getDaGameOver()     const { return m_daGameOver; }
    bool  getDangXoaHang()    const { return m_dangXoaHang; }
    int   getHangRacCho()     const { return m_hangRacCho; }
    int   getKieuHienTai()    const { return m_kieuHienTai; }
    int   getKieuTiepTheo()   const { return m_kieuTiepTheo; }
    Color getMauNguoiChoi()   const { return m_mauNguoiChoi; }
    ToaDo getKhoiHienTai(int i) const { return m_khoiHienTai[i]; }
    int   getLuoi   (int r, int c) const { return m_luoi   [r][c]; }
    int   getLuoiMau(int r, int c) const { return m_luoiMau[r][c]; }
    bool  getHangDay(int i)   const { return m_hangDay[i]; }
    int   getDemHieuUng()     const { return m_demHieuUng; }
    const vector<HieuUngDiem>& getDanhSachHieuUng() const { return m_danhSachHieuUng; }
          vector<HieuUngDiem>& getDanhSachHieuUng()       { return m_danhSachHieuUng; }

    // ---- Setters ----
    void setHangRacCho(int v) { m_hangRacCho = v; }
    void setDiem(int v)       { m_diem = v; }

    // ---- Hanh dong ----
    int buocRoi(float viTriNgang) {
        if (m_dangXoaHang) {
            if (--m_demHieuUng <= 0) { xoaHangDayVaDon(); m_dangXoaHang = false; }
            return 0;
        }
        for (int i = 0; i < 4; i++) { m_khoiDuPhong[i] = m_khoiHienTai[i]; m_khoiHienTai[i].y++; }
        if (!kiemTraHopLe()) {
            for (int i = 0; i < 4; i++) m_khoiHienTai[i] = m_khoiDuPhong[i];
            khoaKhoiXuongLuoi();
            int soHangXoa = demHangDay();
            if (soHangXoa > 0) {
                m_dangXoaHang = true; m_demHieuUng = 2;
                int d = tinhDiemTheoSoHang(soHangXoa); m_diem += d;
                float ex = viTriNgang + (CauHinh::COT * CauHinh::O_SIZE) / 2.f;
                float ey = CauHinh::HANG * CauHinh::O_SIZE / 2.f;
                m_danhSachHieuUng.push_back(HieuUngDiem(ex, ey, d));
                if (soHangXoa == 4) {
                    m_danhSachHieuUng.push_back(HieuUngDiem(ex - 20, ey + 30, 0));
                    m_danhSachHieuUng.back().setNoiDung("TETRIS!");
                }
            }
            taoBienMoi();
            return soHangXoa;
        }
        return 0;
    }

    void diChuyen(int dx) {
        for (int i = 0; i < 4; i++) { m_khoiDuPhong[i] = m_khoiHienTai[i]; m_khoiHienTai[i].x += dx; }
        if (!kiemTraHopLe()) for (int i = 0; i < 4; i++) m_khoiHienTai[i] = m_khoiDuPhong[i];
    }

    void xoay() {
        ToaDo tamXoay = m_khoiHienTai[1];
        for (int i = 0; i < 4; i++) {
            int dx = m_khoiHienTai[i].y - tamXoay.y;
            int dy = m_khoiHienTai[i].x - tamXoay.x;
            m_khoiDuPhong[i] = m_khoiHienTai[i];
            m_khoiHienTai[i].x = tamXoay.x - dx;
            m_khoiHienTai[i].y = tamXoay.y + dy;
        }
        if (!kiemTraHopLe()) for (int i = 0; i < 4; i++) m_khoiHienTai[i] = m_khoiDuPhong[i];
    }

    void reNhanh() {
        while (true) {
            for (int i = 0; i < 4; i++) { m_khoiDuPhong[i] = m_khoiHienTai[i]; m_khoiHienTai[i].y++; }
            if (!kiemTraHopLe()) { for (int i = 0; i < 4; i++) m_khoiHienTai[i] = m_khoiDuPhong[i]; break; }
        }
    }

    void nhanHangRac(int soHang) {
        if (soHang <= 0) return;
        for (int i = 0; i < CauHinh::HANG - soHang; i++)
            for (int j = 0; j < CauHinh::COT; j++) {
                m_luoi   [i][j] = m_luoi   [i + soHang][j];
                m_luoiMau[i][j] = m_luoiMau[i + soHang][j];
            }
        int viTriLo = rand() % CauHinh::COT;
        for (int i = CauHinh::HANG - soHang; i < CauHinh::HANG; i++)
            for (int j = 0; j < CauHinh::COT; j++) {
                m_luoi   [i][j] = (j == viTriLo) ? 0 : 1;
                m_luoiMau[i][j] = (j == viTriLo) ? 0 : CauHinh::MAU_RAC;
            }
        for (int k = 0; k < soHang; k++) {
            bool biChong = false;
            for (int i = 0; i < 4; i++)
                if (m_khoiHienTai[i].y >= 0 && m_khoiHienTai[i].y < CauHinh::HANG
                    && m_luoi[m_khoiHienTai[i].y][m_khoiHienTai[i].x])
                { biChong = true; break; }
            if (biChong) for (int i = 0; i < 4; i++) m_khoiHienTai[i].y--;
        }
    }

    void capNhatHieuUng(float dt) {
        for (int i = (int)m_danhSachHieuUng.size() - 1; i >= 0; i--)
            if (!m_danhSachHieuUng[i].capNhat(dt))
                m_danhSachHieuUng.erase(m_danhSachHieuUng.begin() + i);
    }

    // ---- Luu / Nap ----
    void luuTrangThai(ofstream& f) {
        for (int i = 0; i < CauHinh::HANG; i++)
            for (int j = 0; j < CauHinh::COT; j++) {
                ghiSoNguyen(f, m_luoi   [i][j]);
                ghiSoNguyen(f, m_luoiMau[i][j]);
            }
        for (int i = 0; i < 4; i++) {
            ghiSoNguyen(f, m_khoiHienTai[i].x);
            ghiSoNguyen(f, m_khoiHienTai[i].y);
        }
        ghiSoNguyen(f, m_kieuHienTai); ghiSoNguyen(f, m_kieuTiepTheo); ghiSoNguyen(f, m_diem);
    }

    void napTrangThai(ifstream& f) {
        for (int i = 0; i < CauHinh::HANG; i++)
            for (int j = 0; j < CauHinh::COT; j++) {
                m_luoi   [i][j] = docSoNguyen(f);
                m_luoiMau[i][j] = docSoNguyen(f);
            }
        for (int i = 0; i < 4; i++) {
            m_khoiHienTai[i].x = docSoNguyen(f);
            m_khoiHienTai[i].y = docSoNguyen(f);
        }
        m_kieuHienTai = docSoNguyen(f); m_kieuTiepTheo = docSoNguyen(f); m_diem = docSoNguyen(f);
        m_daGameOver = false; m_dangXoaHang = false; m_hangRacCho = 0;
        m_danhSachHieuUng.clear();
    }

    // ---- Ve ----
    void veBanChoi(RenderWindow& cua_so, int viTriNgang, Font& phong_chu) {
        RectangleShape nen(Vector2f(CauHinh::COT * CauHinh::O_SIZE, CauHinh::HANG * CauHinh::O_SIZE));
        nen.setPosition(viTriNgang, 0); nen.setFillColor(Color(15, 15, 30)); cua_so.draw(nen);

        RectangleShape duongDoc(Vector2f(1, CauHinh::HANG * CauHinh::O_SIZE));
        duongDoc.setFillColor(Color(40, 40, 60));
        for (int j = 1; j < CauHinh::COT; j++) {
            duongDoc.setPosition(viTriNgang + j * CauHinh::O_SIZE, 0); cua_so.draw(duongDoc);
        }
        RectangleShape duongNgang(Vector2f(CauHinh::COT * CauHinh::O_SIZE, 1));
        duongNgang.setFillColor(Color(40, 40, 60));
        for (int i = 1; i < CauHinh::HANG; i++) {
            duongNgang.setPosition(viTriNgang, i * CauHinh::O_SIZE); cua_so.draw(duongNgang);
        }

        RectangleShape o(Vector2f(CauHinh::O_SIZE - 2.f, CauHinh::O_SIZE - 2.f));
        for (int i = 0; i < CauHinh::HANG; i++)
            for (int j = 0; j < CauHinh::COT; j++) {
                if (!m_luoi[i][j]) continue;
                int ci = m_luoiMau[i][j] - 1;
                Color mauO = (ci == CauHinh::MAU_RAC - 1) ? Color(100,100,100)
                    : (ci >= 0 && ci < CauHinh::SO_KIEU) ? bangMauKhoi[ci] : m_mauNguoiChoi;
                if (m_dangXoaHang && m_hangDay[i])
                    mauO = (m_demHieuUng % 3 == 0) ? Color::White : Color(mauO.r/2, mauO.g/2, mauO.b/2);
                o.setFillColor(mauO);
                o.setPosition(viTriNgang + j * CauHinh::O_SIZE + 1, i * CauHinh::O_SIZE + 1);
                cua_so.draw(o);
                RectangleShape sang(Vector2f(CauHinh::O_SIZE - 2.f, 3.f));
                sang.setFillColor(Color(255,255,255,60));
                sang.setPosition(viTriNgang + j * CauHinh::O_SIZE + 1, i * CauHinh::O_SIZE + 1);
                cua_so.draw(sang);
            }

        ToaDo bong[4]; tinhViTriBong(bong);
        Color mauBong = bangMauKhoi[m_kieuHienTai]; mauBong.a = 60;
        o.setFillColor(mauBong);
        for (int i = 0; i < 4; i++) if (bong[i].y >= 0) {
            o.setPosition(viTriNgang + bong[i].x * CauHinh::O_SIZE + 1, bong[i].y * CauHinh::O_SIZE + 1);
            cua_so.draw(o);
        }
        Color mauKhoi = bangMauKhoi[m_kieuHienTai]; mauKhoi.a = 255;
        o.setFillColor(mauKhoi);
        for (int i = 0; i < 4; i++) if (m_khoiHienTai[i].y >= 0) {
            o.setPosition(viTriNgang + m_khoiHienTai[i].x * CauHinh::O_SIZE + 1,
                          m_khoiHienTai[i].y * CauHinh::O_SIZE + 1);
            cua_so.draw(o);
            RectangleShape sang(Vector2f(CauHinh::O_SIZE - 2.f, 3.f));
            sang.setFillColor(Color(255,255,255,80));
            sang.setPosition(viTriNgang + m_khoiHienTai[i].x * CauHinh::O_SIZE + 1,
                             m_khoiHienTai[i].y * CauHinh::O_SIZE + 1);
            cua_so.draw(sang);
        }
        RectangleShape khung(Vector2f(CauHinh::COT * CauHinh::O_SIZE, CauHinh::HANG * CauHinh::O_SIZE));
        khung.setPosition(viTriNgang, 0); khung.setFillColor(Color::Transparent);
        khung.setOutlineThickness(2); khung.setOutlineColor(Color(100,100,160));
        cua_so.draw(khung);
    }

    void vePanel(RenderWindow& cua_so, int panelX, int panelY, Font& phong_chu, const string& nhan) {
        RectangleShape nen(Vector2f(130, 310));
        nen.setPosition(panelX, panelY); nen.setFillColor(Color(20,20,40,200));
        nen.setOutlineThickness(1); nen.setOutlineColor(Color(80,80,120)); cua_so.draw(nen);
        auto veChu = [&](const string& s, int x, int y, int cz, Color c) {
            Text t(s, phong_chu, cz); t.setPosition((float)x, (float)y); t.setFillColor(c); cua_so.draw(t);
        };
        veChu(nhan,              panelX+10, panelY+8,  16, m_mauNguoiChoi);
        veChu("DIEM",            panelX+10, panelY+35, 12, Color(160,160,200));
        veChu(to_string(m_diem), panelX+10, panelY+52, 22, Color::White);
        veChu("TIEP THEO",       panelX+10, panelY+90, 12, Color(160,160,200));
        int coChuKhoi = 22;
        ToaDo xemTruoc[4];
        for (int i = 0; i < 4; i++) {
            xemTruoc[i].x = dinhNghiaKhoi[m_kieuTiepTheo][i] % 2;
            xemTruoc[i].y = dinhNghiaKhoi[m_kieuTiepTheo][i] / 2;
        }
        RectangleShape oXem(Vector2f(coChuKhoi-2.f, coChuKhoi-2.f));
        oXem.setFillColor(bangMauKhoi[m_kieuTiepTheo]);
        int gocX = panelX+30, gocY = panelY+115;
        for (int i = 0; i < 4; i++) {
            oXem.setPosition(gocX + xemTruoc[i].x * coChuKhoi, gocY + xemTruoc[i].y * coChuKhoi);
            cua_so.draw(oXem);
        }
        if (m_hangRacCho > 0)
            veChu("RAC: " + to_string(m_hangRacCho), panelX+10, panelY+190, 13, Color(255,80,80));
    }

    void veHieuUngDiem(RenderWindow& cua_so, Font& phong_chu) {
        for (auto& hu : m_danhSachHieuUng) {
            bool laTetris = (hu.getNoiDung() == "TETRIS!");
            Text t(hu.getNoiDung(), phong_chu, laTetris ? 26 : 22);
            Uint8 doMo = (Uint8)max(0.f, hu.getDoMo());
            t.setFillColor(laTetris ? Color(255,220,0,doMo) : Color(100,255,100,doMo));
            t.setOutlineColor(Color(0,0,0,doMo)); t.setOutlineThickness(2);
            t.setPosition(hu.getX() - t.getLocalBounds().width / 2.f, hu.getY());
            cua_so.draw(t);
        }
    }
};

// ============================================================
//  CLASS TROCHOI
// ============================================================
class TroChoi {
private:
    RenderWindow m_cuaSo;
    Font         m_phongChu;

    enum class TrangThaiGame {
        Menu, ChonTocDo,
        Choi1Nguoi, Choi2Nguoi, DoiKhang,
        HuongDan, KyLuc
    };
    TrangThaiGame m_trangThai = TrangThaiGame::Menu;

    BanChoiDon m_nguoiChoi1, m_nguoiChoi2;
    Clock      m_dongHo;
    float      m_thoiGianTich = 0, m_dt = 0;
    int        m_diemKyLuc    = 0;
    int        m_mucTocDo     = 1;
    bool       m_cho2Nguoi    = false;
    bool       m_choDoiKhang  = false;
    bool       m_nguoiChoi1DaThua = false;
    bool       m_nguoiChoi2DaThua = false;

    static constexpr int BAN_1P_X     = 200;
