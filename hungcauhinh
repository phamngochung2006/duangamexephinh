    // Overlay "THUA" len ban cua nguoi da thua khi nguoi kia van choi tiep
    void veOverlayDaThua(int viTriNgang, const string& dongChu2) {
        RectangleShape man(Vector2f(CauHinh::COT * CauHinh::O_SIZE, CauHinh::HANG * CauHinh::O_SIZE));
        man.setPosition(viTriNgang, 0);
        man.setFillColor(Color(0, 0, 0, 180));
        cuaSo.draw(man);
 
        Text chuThua("THUA", phongChu, 32);
        chuThua.setFillColor(Color(220, 60, 60));
        chuThua.setPosition(
            viTriNgang + CauHinh::COT * CauHinh::O_SIZE / 2.f - chuThua.getLocalBounds().width / 2.f,
            CauHinh::HANG * CauHinh::O_SIZE / 2.f - 20);
        cuaSo.draw(chuThua);
 
        Text chuCho(dongChu2, phongChu, 14);
        chuCho.setFillColor(Color(200, 200, 200));
        chuCho.setPosition(
            viTriNgang + CauHinh::COT * CauHinh::O_SIZE / 2.f - chuCho.getLocalBounds().width / 2.f,
            CauHinh::HANG * CauHinh::O_SIZE / 2.f + 22);
        cuaSo.draw(chuCho);
    }
 
