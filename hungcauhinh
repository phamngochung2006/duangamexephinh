//  CLASS TROCHOI - quan ly vong lap chinh va cac che do choi
// ============================================================
class TroChoi {
    RenderWindow cuaSo;
    Font phongChu;
 
    enum class TrangThaiGame {
        Menu, ChonTocDo,
        Choi1Nguoi, Choi2Nguoi, DoiKhang,
        HuongDan, KyLuc
    };
    TrangThaiGame trangThai = TrangThaiGame::Menu;
 
    BanChoiDon nguoiChoi1, nguoiChoi2;
    Clock dongHo;
    float thoiGianTich = 0, dt = 0;
    int   diemKyLuc    = 0;
    int   mucTocDo     = 1;
    bool  cho2Nguoi    = false;
    bool  choDoiKhang  = false;
 
    // Trang thai chet rieng biet: cho phep nguoi con lai choi tiep
    bool nguoiChoi1DaThua = false;
