        if (m_nguoiChoi2DaThua && !m_nguoiChoi1DaThua) veOverlayDaThua(BAN_DK_2_X,"Dang cho P1...");
        veMuiTenDoiKhangGiua();
        m_nguoiChoi1.veHieuUngDiem(m_cuaSo,m_phongChu); m_nguoiChoi2.veHieuUngDiem(m_cuaSo,m_phongChu);
    }

public:
    // ---- Getters ----
    int  getDiemKyLuc()   const { return m_diemKyLuc; }
    int  getMucTocDo()    const { return m_mucTocDo; }
    bool getCho2Nguoi()   const { return m_cho2Nguoi; }
    bool getChoDoiKhang() const { return m_choDoiKhang; }

    // ---- Setters ----
    void setMucTocDo(int v)     { m_mucTocDo = v; }
    void setCho2Nguoi(bool v)   { m_cho2Nguoi = v; }
    void setChoDoiKhang(bool v) { m_choDoiKhang = v; }

    TroChoi() : m_cuaSo(VideoMode(820, CauHinh::HANG*CauHinh::O_SIZE+60), "Xep Hinh") {
        srand((unsigned int)time(0));
        try {
            if (!m_phongChu.loadFromFile("C:/Windows/Fonts/arial.ttf"))
                throw runtime_error("Khong tim thay font arial");
        } catch (...) {
            if (!m_phongChu.loadFromFile("/usr/share/fonts/truetype/liberation/LiberationMono-Regular.ttf"))
                cerr << "[CANH BAO] Khong tai duoc font chu.\n";
        }
        docKyLuc();
    }

    void chay() {
        while (m_cuaSo.isOpen()) {
            m_dt = m_dongHo.restart().asSeconds();
            if (m_dt > 0.1f) m_dt = 0.1f;
            m_thoiGianTich += m_dt;
            Event sk;
            while (m_cuaSo.pollEvent(sk)) {
                if (sk.type == Event::Closed) {
                    if (m_trangThai==TrangThaiGame::Choi1Nguoi) luuGame1Nguoi();
                    if (m_trangThai==TrangThaiGame::Choi2Nguoi) luuGame2Nguoi();
                    m_cuaSo.close();
                }
                if (sk.type == Event::KeyPressed) xuLyPhimNhan(sk);
            }
            m_cuaSo.clear(Color(10,10,22));
            switch (m_trangThai) {
            case TrangThaiGame::Menu:       veManHinhMenu();      break;
            case TrangThaiGame::ChonTocDo:  veManHinhChonTocDo(); break;
            case TrangThaiGame::Choi1Nguoi: choi1Nguoi();         break;
            case TrangThaiGame::Choi2Nguoi: choi2Nguoi();         break;
            case TrangThaiGame::DoiKhang:   choiDoiKhang();       break;
            case TrangThaiGame::HuongDan:   veManHinhHuongDan();  break;
            case TrangThaiGame::KyLuc:      veManHinhKyLuc();     break;
            }
            m_cuaSo.display();
        }
    }
};

